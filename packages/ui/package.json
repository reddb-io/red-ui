{
  "name": "@reddb-io/ui",
  "version": "0.1.1",
  "private": false,
  "description": "RedDB UI components and standalone web application.",
  "type": "module",
  "bin": {
    "red-ui": "./bin/red-ui.js"
  },
  "svelte": "./src/lib/index.ts",
  "imports": {
    "#reddb": {
      "types": "./src/lib/reddb/index.ts",
      "default": "./src/lib/reddb/index.ts"
    }
  },
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts",
      "types": "./src/lib/index.ts"
    },
    "./app.css": "./src/app.css",
    "./renderers": {
      "svelte": "./src/lib/renderers/index.ts",
      "types": "./src/lib/renderers/index.ts"
    },
    "./build/*": "./build/*"
  },
  "files": [
    "bin",
    "build",
    "src/app.css",
    "src/lib/**/*.svelte",
    "src/lib/**/*.ts",
    "!src/lib/**/*.test.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm build",
    "dev": "vite dev --host 127.0.0.1 --port 1420 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "svelte-kit sync && vitest run"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@reddb-io/ui-mcp": "workspace:*",
    "@reddb-io/ui-kit": "workspace:*",
    "@tauri-apps/api": "^2.5.0",
    "@xyflow/svelte": "^1.2.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "lucide-svelte": "^0.475.0",
    "sigma": "^3.0.3",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^2.1.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.17.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/reddb-io/red-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reddb-io/red-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/reddb-io/red-ui/issues"
  }
}
