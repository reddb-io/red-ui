node_modules/
dist/
build/
.svelte-kit/
.turbo/
.DS_Store
*.log

# Tauri
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/WixTools/

# env
.env
.env.local
.env.*.local

# Local embedded data
.data/
.red/tmp/
.red/state/
.red/memory/

# Stray .red/ runtime dirs that AFK workers create inside package/source trees.
# The tracked root .red/ (CONTEXT.md, adr/, agents/, config.yaml) is re-included
# below so future ADRs etc. stay visible.
**/.red/
!/.red/

# Per-machine Claude Code overrides — e.g. the absolute statusline path
# needed because ${CLAUDE_PLUGIN_ROOT} doesn't resolve at project scope.
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Tauri sidecar binaries — ~15MB platform blobs, provisioned per-machine via
# scripts/sync-desktop-sidecar.sh (and in CI before the tauri job).
apps/desktop/src-tauri/binaries/*
!apps/desktop/src-tauri/binaries/.gitkeep
